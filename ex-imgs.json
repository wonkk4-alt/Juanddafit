        React.createElement('div',{style:{background:'#0d1b2a',border:'2px solid #ef444460',borderRadius:20,padding:28,maxWidth:340,width:'100%',textAlign:'center'},onClick:e=>e.stopPropagation()},
          React.createElement('div',{style:{fontSize:44,marginBottom:12}},'🔒'),
          React.createElement('div',{style:{fontWeight:900,fontSize:17,color:'#ef4444',marginBottom:10,fontFamily:"'Rajdhani',sans-serif",letterSpacing:'.05em'}},'VIDEO BLOQUEADO'),
