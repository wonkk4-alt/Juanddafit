// Helper: render an avatar circle (photo or initial)
function AvatarCircle({user,size=72,fontSize=28}){
  // Soporta URLs de Firebase Storage (https://...) y base64 (data:...)
  const hasPhoto=user.avatar&&(user.avatar.startsWith('data:')||user.avatar.startsWith('http'));
  return React.createElement('div',{style:{width:size,height:size,borderRadius:'50%',background:hasPhoto?'transparent':'#00bcd4',display:'inline-flex',alignItems:'center',justifyContent:'center',fontSize,color:'#fff',fontWeight:900,overflow:'hidden',flexShrink:0,border:'2px solid #00bcd433'}},
    hasPhoto?React.createElement('img',{loading:'lazy',decoding:'async',src:user.avatar,style:{width:'100%',height:'100%',objectFit:'cover'},onError:e=>{e.target.style.display='none';}}):(user.name&&user.name[0]||'U')
  );
}



function BodyCompositionChart({user,compact=false}){
  user=user||{};
  function num(v){
    if(v===null||v===undefined||v==='')return null;
    const n=parseFloat((''+v).replace(',','.').replace('%',''));
    return isNaN(n)?null:n;
  }
  function nice(n){
    if(n===null&&n!==0)return '';
    return (Math.round(n*10)/10).toString().replace('.',',');
  }
  function clamp(n,min,max){return Math.max(min,Math.min(max,n));}

  const grasaCorporal=num(user.grasaCorporal!==undefined&&user.grasaCorporal!==''?user.grasaCorporal:user.porcentajeGrasa);
  const masaMuscular=num(user.masaMuscular!==undefined&&user.masaMuscular!==''?user.masaMuscular:user.porcentajeMasa);
  const imc=num(user.imc);
  const grasaVisceral=num(user.grasaVisceral);

  const hasPie=(grasaCorporal!==null)||(masaMuscular!==null);
  const hasIndicators=(imc!==null)||(grasaVisceral!==null);
  if(!hasPie&&!hasIndicators)return null;

  let fat=grasaCorporal===null?0:clamp(grasaCorporal,0,100);
  let muscle=masaMuscular===null?0:clamp(masaMuscular,0,100);
  let rest=Math.max(0,100-fat-muscle);

  // Si los porcentajes suman más de 100, se normalizan solo para el dibujo.
  // Los valores reales se mantienen en la leyenda.
  if(fat+muscle>100){
    const scale=100/(fat+muscle);
    fat=fat*scale;
    muscle=muscle*scale;
    rest=0;
  }

  const pieItems=[
    {key:'grasaCorporal',label:'Grasa corporal',value:grasaCorporal,draw:fat,unit:'%',color:'#ff4d6d'},
    {key:'masaMuscular',label:'Masa muscular',value:masaMuscular,draw:muscle,unit:'%',color:'#00e5ff'},
    {key:'otros',label:'Otros componentes',value:Math.round(rest*10)/10,draw:rest,unit:'%',color:'#7c3aed'}
  ].filter(x=>x.key==='otros'||x.value!==null);

  let start=0;
  const segments=pieItems.map(x=>{
    const seg={...x,start,end:start+(x.draw||0)};
    start+=(x.draw||0);
    return seg;
  });
  const gradient=hasPie
    ? 'conic-gradient('+segments.map(s=>`${s.color} ${s.start}% ${s.end}%`).join(', ')+')'
    : 'conic-gradient(#1e3347 0 100%)';

  function LegendItem({item}){
    return React.createElement('div',{style:{
      display:'grid',
      gridTemplateColumns:'12px 1fr auto',
      alignItems:'center',
      gap:8,
      background:'#0d2030',
      border:'1px solid '+item.color+'55',
      borderRadius:10,
      padding:'8px 10px'
    }},
      React.createElement('span',{style:{width:12,height:12,borderRadius:'50%',background:item.color,boxShadow:'0 0 12px '+item.color}}),
      React.createElement('div',null,
        React.createElement('div',{style:{fontSize:11,color:'#e2f7fb',fontWeight:900,lineHeight:1.05}},item.label),
        React.createElement('div',{style:{fontSize:9,color:'#7aadbe',fontWeight:700,marginTop:2}},
          item.key==='otros'?'Porción restante del 100%':'Porcentaje ingresado'
        )
      ),
      React.createElement('div',{style:{fontSize:14,color:'#ffffff',fontWeight:900}},
        (item.value===null?'—':nice(item.value))+item.unit
      )
    );
  }

  function Indicator({label,value,color,sub}){
    if(value===null&&value!==0)return null;
    return React.createElement('div',{style:{
      background:'#0d2030',
      border:'1px solid '+color+'66',
      borderRadius:12,
      padding:'10px 12px',
      display:'grid',
      gridTemplateColumns:'12px 1fr auto',
      alignItems:'center',
      gap:8
    }},
      React.createElement('span',{style:{width:12,height:12,borderRadius:'50%',background:color,boxShadow:'0 0 12px '+color}}),
      React.createElement('div',null,
        React.createElement('div',{style:{fontSize:11,color:'#e2f7fb',fontWeight:900}},label),
