          React.createElement('div',{style:{fontWeight:900,fontSize:17,color:'#e2f7fb',fontFamily:"'Rajdhani',sans-serif",lineHeight:1.2}},ex.name),
          React.createElement('div',{style:{fontSize:12,color:'#7aadbe',marginTop:4}},localSets+' series × '+localReps+' reps · '+localRest+'s desc')
        )
      ),

      // Nota del entrenador
      note&&React.createElement('div',{style:{
        background:'linear-gradient(135deg,#1a1230,#0f1528)',
        border:'1.5px solid #7c3aed44',borderRadius:14,
