// ─── DAY EDIT (trainer edits user routine) ────────────────────────────────────
function DayEditTrainer({user:u,trainer,day,exercises,notes,onBack,onSave,onUpdateEx,onSetRtn,onSaveNote}){
  const [tab,setTab]=useState('exercises'); // exercises | add
  const [openCat,setOpenCat]=useState(null);
  const [noteEditing,setNoteEditing]=useState(null); // exerciseId
  const [noteDraft,setNoteDraft]=useState('');
  const [exEditing,setExEditing]=useState(null); // exerciseId for global info edit
  const [exInfoDraft,setExInfoDraft]=useState({links:[],description:''}); // draft glo
  const [exEditErr,setExEditErr]=useState(''); // error al abrir/guardar info ejerciciobal info (links: [{url,label}])
  const [exInfoCache,setExInfoCache]=useState({}); // exId -> info from Firestore
  const [savingEx,setSavingEx]=useState(false);
  const [catalogVersion,setCatalogVersion]=useState(0);
  const [newExOpen,setNewExOpen]=useState(false);
  const [newExDraft,setNewExDraft]=useState(defaultNewExerciseDraft());
  const [savingNewEx,setSavingNewEx]=useState(false);
  const [deletingExId,setDeletingExId]=useState(null);

  // Load global custom exercise catalog and global deletions; keep them synced for all trainers.
  useEffect(()=>{
    let mounted=true;
    function bump(){ if(mounted)setCatalogVersion(v=>v+1); }
    function applyCatalog(customs){
      mergeCustomExercises(customs||[]);
      bump();
    }
    function applyDeleted(ids){
      applyDeletedExerciseIds(ids||[]);
      bump();
    }
    async function loadCustomCatalog(){
      try{
        const customs = await DB.getCustomExercises();
        applyCatalog(customs);
      }catch(e){
        console.warn('custom exercise catalog error:', e);
      }
    }
    async function loadDeletedCatalog(){
      try{
        const ids = await DB.getDeletedExerciseIds();
        applyDeleted(ids);
      }catch(e){
        console.warn('deleted exercise catalog error:', e);
      }
    }
    loadDeletedCatalog();
    loadCustomCatalog();
    const unsubCustom = DB.watchCustomExercises(applyCatalog);
    const unsubDeleted = DB.watchDeletedExercises(applyDeleted);
    return ()=>{
      mounted=false;
      if(typeof unsubCustom==='function')unsubCustom();
      if(typeof unsubDeleted==='function')unsubDeleted();
    };
  },[]);

  // Load exInfo for all exercises in this day
  useEffect(()=>{
    let mounted=true;
    async function loadAllInfo(){
      const cache={};
      for(const ex of exercises){
        try{
          const info=await DB.getExInfo(ex.id);
          if(info)cache[ex.id]=info;
        }catch(e){
          console.warn('getExInfo cache error:', ex.id, e);
        }
      }
      if(mounted) setExInfoCache(cache);
    }
    if(exercises.length)loadAllInfo();
    else setExInfoCache({});
    return ()=>{mounted=false;};
  },[exercises]);

  async function openExEdit(exId){
    setExEditErr('');
    let info;
    try{ info=await DB.getExInfo(exId); }
    catch(e){ setExEditErr('Error al cargar info: '+(e.message||'verifica conexión')); return; }
    const baseEx=exercises.find(e=>e.id===exId)||{};
    let links=[];
    if(!info){
      // Nunca editado: pre-cargar links originales del catálogo para comodidad
      const defaultLabels=['Tutorial principal','Tutorial alternativo','Tutorial extra'];
      [baseEx.video,baseEx.video2,baseEx.video3].forEach((u,i)=>{
        if(u)links.push({url:u,label:defaultLabels[i]});
      });
      if(baseEx.link)links.push({url:baseEx.link,label:baseEx.linkLabel||'Enlace'});
    } else if(Array.isArray(info.links)){
      // Ya fue editado: respetar su lista aunque sea vacía
      links=info.links.map(l=>({url:l.url||'',label:l.label||''}));
    } else {
      // Registro legacy (campos video/video2/video3) → migrar
      const defaultLabels=['Tutorial principal','Tutorial alternativo','Tutorial extra'];
      ['video','video2','video3'].forEach((k,i)=>{
        if(info[k])links.push({url:info[k],label:defaultLabels[i]});
      });
      if(info.link)links.push({url:info.link,label:info.linkLabel||'Enlace del entrenador'});
    }
    setExInfoDraft({name:(info&&info.name)||baseEx.name||'',links,description:info?info.description||'':'',customImg:(info&&info.customImg)||baseEx.customImg||''});
    setExEditing(exId);
  }

  async function saveExInfo(){
    setSavingEx(true);
    try{
      const cleanLinks=(exInfoDraft.links||[]).filter(l=>l.url&&l.url.trim());
      const baseEx=(exercises.find(e=>e.id===exEditing)||{});
      const dataToSave={name:(exInfoDraft.name||'').trim()||baseEx.name||'',links:cleanLinks,description:exInfoDraft.description||'',customImg:exInfoDraft.customImg||''};
      await DB.saveExInfo(exEditing,dataToSave);
      setExInfoCache(c=>({...c,[exEditing]:{...dataToSave}}));
      onSetRtn(rtn=>Array.isArray(rtn)?rtn.map(item=>item&&item.id===exEditing?{...item,name:dataToSave.name||item.name}:item):rtn);
      mergeCustomExercises([{...baseEx,...dataToSave,id:exEditing,category:baseEx.category||baseEx.cat}]);
      setCatalogVersion(v=>v+1);
      setExEditing(null);
    }catch(e){
      console.error('saveExInfo error:',e);
      alert('Error al guardar info: '+(e.message||'verifica conexión'));
    }
    setSavingEx(false);
  }

  function removeEx(id){onSetRtn(rtn=>rtn.filter(e=>e.id!==id));}
  function addEx(ex){
    if(exercises.find(e=>e.id===ex.id)){onSetRtn(rtn=>rtn.filter(e=>e.id!==ex.id));return;}
    onSetRtn(rtn=>[...rtn,{...ex,sets:3,reps:10,rest:60}]);
  }

  function handleNewExerciseImageFile(file){
    if(!file)return;
    compressImageFile(file, dataUrl=>setNewExDraft(d=>({...d,image:dataUrl})), ()=>alert('No se pudo cargar la imagen.'));
  }

  function handleEditExerciseImageFile(file){
    if(!file)return;
    compressImageFile(file, dataUrl=>setExInfoDraft(d=>({...d,customImg:dataUrl})), ()=>alert('No se pudo cargar la imagen.'));
  }

  async function createNewExercise(){
    const name=(newExDraft.name||'').trim();
    const category=newExDraft.category;
    if(!name){ alert('Escribe el nombre del ejercicio.'); return; }
    if(!category || !CAT[category]){ alert('Selecciona una categoría válida.'); return; }
    setSavingNewEx(true);
    try{
      const id='C'+Date.now().toString(36).toUpperCase()+Math.random().toString(36).slice(2,6).toUpperCase();
      const link=(newExDraft.link||'').trim();
      const image=(newExDraft.image||'').trim();
      const ex={
        id, name, category, custom:true, customImg:image,
        zone:'Personalizado', machine:'Personalizado', video:link
      };
      const info={
        ...ex,
        isCustomExercise:true,
        links:link?[{url:link,label:'Tutorial principal'}]:[],
        description:(newExDraft.description||'').trim(),
        createdBy:(trainer&&trainer.uid)||(trainer&&trainer.email)||'',
        createdAt:Date.now()
      };
      await DB.saveCustomExercise(ex,info);
      mergeCustomExercises([info]);
      setExInfoCache(c=>({...c,[id]:info}));
      setCatalogVersion(v=>v+1);
      setOpenCat(category);
      setNewExDraft(defaultNewExerciseDraft());
      setNewExOpen(false);
      setTab('add');
      alert('Ejercicio creado en el catálogo global. Para asignarlo, selecciónalo en la categoría correspondiente y luego guarda la rutina del cliente.');
    }catch(e){
      console.error('createNewExercise error:',e);
      alert('Error al crear el ejercicio: '+(e.message||'verifica conexión'));
    }
    setSavingNewEx(false);
  }

  async function deleteExerciseFromApp(ex){
    if(!ex || !ex.id)return;
    const msg = '¿Eliminar "'+(ex.name||ex.id)+'" del catálogo global de la app?\n\nDesaparecerá para entrenadores y clientes al volver a cargar/entrar. Si estaba en esta rutina, también se quitará aquí.';
    if(!confirm(msg))return;
    setDeletingExId(ex.id);
    try{
      await DB.deleteExerciseFromApp(ex);
      applyDeletedExerciseIds([ex.id]);
      setExInfoCache(c=>{ const n={...c}; delete n[ex.id]; return n; });
      onSetRtn(rtn=>Array.isArray(rtn)?rtn.filter(item=>item&&item.id!==ex.id):rtn);
      if(exEditing===ex.id)setExEditing(null);
      setCatalogVersion(v=>v+1);
      alert('Ejercicio eliminado del catálogo global.');
    }catch(e){
      console.error('deleteExerciseFromApp error:', e);
      alert('No se pudo eliminar el ejercicio: '+(e.message||'verifica conexión y permisos de Firestore'));
    }
    setDeletingExId(null);
  }

