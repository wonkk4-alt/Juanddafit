  // ── Asistencia ────────────────────────────────────────────────────────────────
  async setAtt(uid, day, status){
    await ensureFirebaseReady();
    const week = new Date().toISOString().slice(0,7);
    // Guardar como objeto anidado real: { "2026-06": { lun: {...} } }
    // Antes se usaba una clave con punto (`2026-06.lun`), pero getWeekAtt
    // lee datos anidados; por eso el día no quedaba verde aunque se guardara.
    await db_fs.collection('attendance').doc(uid).set({
      [week]: {
        [day]: {s: status, t: Date.now()}
      }
    }, {merge: true});
    return true;
  },

  async getWeekAtt(uid){
    await ensureFirebaseReady();
    const week = new Date().toISOString().slice(0,7);
    const snap = await db_fs.collection('attendance').doc(uid).get();
    if(!snap.exists) return {};
    const data = snap.data() || {};
    const nested = data[week] || {};
    // Compatibilidad con registros viejos guardados como "2026-06.lun".
    const legacy = {};
    Object.keys(data).forEach(k=>{
      if(k.indexOf(week+'.')===0){
        legacy[k.slice(week.length+1)] = data[k];
      }
    });
    return Object.assign({}, legacy, nested);
  },

  // ── Logs de ejercicio ─────────────────────────────────────────────────────────
  async getExerciseLog(uid, exId, date){
    await ensureFirebaseReady();
    const snap = await db_fs.collection('exerciseLogs').doc(uid).get();
    if(!snap.exists) return null;
    const data = snap.data() || {};
    // Formato correcto: { "2026-06-07": { E001: {...} } }
    const nested = (data[date] || {})[exId];
    // Compatibilidad con logs viejos guardados como clave plana "2026-06-07.E001".
    const legacy = data[`${date}.${exId}`];
    return nested || legacy || null;
  },

  async saveExerciseLog(uid, exId, date, data){
    await ensureFirebaseReady();
    // Guardar como objeto anidado real para que getExerciseLog pueda leerlo.
    await db_fs.collection('exerciseLogs').doc(uid).set({
      [date]: {
        [exId]: data
      }
    }, {merge: true});
    return true;
  },

  // ── Stubs compatibilidad ──────────────────────────────────────────────────────
  async updateActivity(uid, name){
    await ensureFirebaseReady(); return true; },
  async getActivity(){
    await ensureFirebaseReady(); return []; },
  watchUserProfile(uid, cb){
