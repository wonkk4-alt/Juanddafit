  async getAvatarUrl(uid){
    await ensureFirebaseReady(); return null; },

  // ── Trainer auth con PIN ─────────────────────────────────────────────────────
  async loginTrainer(email, pin){
    await ensureFirebaseReady();
    // El trainer se autentica por email+PIN guardado en Firestore
    const q = await db_fs.collection('users').where('email','==',email.trim().toLowerCase()).where('role','==','trainer').limit(1).get();
    if(q.empty) throw new Error('No se encontró el entrenador.');
    const doc = q.docs[0].data();
    if(doc.pin !== pin) throw new Error('PIN incorrecto.');
    return doc;
  },

  // ── Rutinas ──────────────────────────────────────────────────────────────────
  async getRoutine(uid){
    await ensureFirebaseReady();
    const snap = await db_fs.collection('routines').doc(uid).get();
    const days = snap.exists ? (snap.data().days || {}) : {};
    // Filtro rápido solo con caché local. No bloquea la carga consultando Firestore.
    try{
      const localDeleted = (this.getDeletedExerciseIdsLocal ? this.getDeletedExerciseIdsLocal() : []);
      if(localDeleted && localDeleted.length){
        const deletedSet = new Set(localDeleted);
        Object.keys(days).forEach(day=>{
          if(Array.isArray(days[day])) days[day] = days[day].filter(ex=>ex && !deletedSet.has(ex.id));
        });
      }
      if(this.refreshDeletedExerciseIds) this.refreshDeletedExerciseIds();
    }catch(e){}
    return days;
  },

  async getAllRoutines(uid){
    await ensureFirebaseReady();
    return this.getRoutine(uid);
  },

  async saveRoutine(uid, day, exercises){
    await ensureFirebaseReady();
    // Guardar como objeto anidado real que Firestore entiende
    var update = {};
    update['days'] = {};
    // Primero leer la rutina actual y mergear
    try{
      var existing = await this.getRoutine(uid);
      update['days'] = Object.assign({}, existing);
    }catch(e){}
    update['days'][day] = exercises;
    await db_fs.collection('routines').doc(uid).set(update, {merge: true});
    return true;
  },

