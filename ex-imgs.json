      // ── Marcar asistencia ──
      !att&&exs.length>0&&React.createElement('div',{style:{marginBottom:12}},
        React.createElement('div',{style:{fontSize:10,fontWeight:700,color:'#7aadbe',letterSpacing:'.1em',marginBottom:8,textAlign:'center'}},'¿TERMINASTE?'),
        React.createElement('div',{style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:8}},
          React.createElement('button',{className:'btn',onClick:()=>markAtt('done'),style:{background:'linear-gradient(135deg,#16a34a,#15803d)',color:'#fff',fontSize:13,padding:'12px',borderRadius:12,border:'none'}},'Completado'),
          React.createElement('button',{className:'btn',onClick:()=>markAtt('missed'),style:{background:'transparent',border:'1.5px solid #1e4a6a',color:'#7aadbe',fontSize:13,padding:'12px',borderRadius:12}},'No completado')
        )
      ),
      att&&React.createElement('div',{style:{textAlign:'center',padding:'14px',fontSize:13,fontWeight:700,color:att.s==='done'?'#4ade80':'#5a8fa8',borderRadius:12,background:'#152535',border:'1px solid #1e4a6a'}},
        att.s==='done'?'Entrenamiento completado':'No completado')
    )
  );
}

// ─── EXERCISE SCREEN ──────────────────────────────────────────────────────────
function ExerciseScreen({user,day,exercise:ex,routine,onBack}){
  const today=new Date().toISOString().slice(0,10);

  const [log,setLog]=useState(null);
  const [note,setNote]=useState('');
  const [exInfo,setExInfo]=useState(null);
  const [helpSent,setHelpSent]=useState(false);
  const [helping,setHelping]=useState(false);
  const [restTimer,setRestTimer]=useState(null);
  const [localSets,setLocalSets]=useState(parseInt(ex.sets)||3);
  const [localReps,setLocalReps]=useState(parseInt(ex.reps)||10);
  const [localRest,setLocalRest]=useState(parseInt(ex.rest)||60);
  const [unlockedVideos,setUnlockedVideos]=useState(null); // null = loading
  const [showVideoLocked,setShowVideoLocked]=useState(false);

  const restRef=React.useRef(null);

  // Cargar log + nota + info del ejercicio + videos desbloqueados
  useEffect(()=>{
    async function load(){
      const l=await DB.getExerciseLog(user.uid,ex.id,today);
      if(l){setLog(l);}
      else{setLog({sets:Array.from({length:localSets},(_,i)=>({reps:localReps,done:false,repsDone:localReps})),allDone:false});}
      const n=await DB.getNote(user.uid,ex.id);
      setNote(n||'');
      const info=await DB.getExInfo(ex.id);
      setExInfo(info||null);
      try{
        const uv=await DB.getUnlockedVideos(user.uid);
        setUnlockedVideos(uv||[]);
      }catch(e){
        setUnlockedVideos([]);
      }
    }
    load();
    return()=>{if(restRef.current)clearInterval(restRef.current);};
  },[ex.id]);

  function startRest(sec){
    if(restRef.current)clearInterval(restRef.current);
    setRestTimer(sec);
    restRef.current=setInterval(()=>{
      setRestTimer(p=>{
        if(p<=1){clearInterval(restRef.current);setRestTimer(null);return 0;}
        return p-1;
      });
    },1000);
  }

  async function maybeAutoCompleteDay(currentExerciseId, currentLog){
    if(!routine || routine.length===0 || !currentLog || !currentLog.allDone)return;
    try{
      let completed=0;
      for(const rex of routine){
        const l = rex.id===currentExerciseId ? currentLog : await DB.getExerciseLog(user.uid,rex.id,today);
        if(l && l.allDone)completed++;
      }
      if(completed===routine.length){
        await DB.setAtt(user.uid,day,'done');
      }
    }catch(e){console.warn('No se pudo autocompletar el día:',e);}
  }

  async function toggleSet(i){
    if(!log)return;
    const wasDown=!log.sets[i].done;
    const newSets=log.sets.map((s,idx)=>idx===i?{...s,done:!s.done}:s);
    const allDone=newSets.every(s=>s.done);
    const nl={...log,sets:newSets,allDone};
    setLog(nl);
    await DB.saveExerciseLog(user.uid,ex.id,today,nl);
    if(allDone)await maybeAutoCompleteDay(ex.id,nl);
    if(wasDown)startRest(localRest);
  }

  async function updateRepsDone(i,val){
    if(!log)return;
    const newSets=log.sets.map((s,idx)=>idx===i?{...s,repsDone:parseInt(val)||0}:s);
    const nl={...log,sets:newSets,allDone:newSets.every(s=>s.done)};
    setLog(nl);
    await DB.saveExerciseLog(user.uid,ex.id,today,nl);
  }

  async function changeSets(delta){
    const ns=Math.max(1,localSets+delta);
    setLocalSets(ns);
    const newSets=Array.from({length:ns},(_,i)=>(log && log.sets ? log.sets[i] : null)||{reps:localReps,done:false,repsDone:localReps});
    const nl={...(log||{}),sets:newSets,allDone:newSets.every(s=>s.done)};
    setLog(nl);
    await DB.saveExerciseLog(user.uid,ex.id,today,nl);
  }

  async function sendHelp(){
    setHelping(true);
    try{
      await DB.postHelp({userId:user.uid,userName:user.name,day:DAY_LABELS[day],
        exercise:ex.name,exerciseId:ex.id,
        exercisesTotal:routine.length,
        age:user.age,cond:user.cond});
      setHelpSent(true);
    }catch(e){}
    setHelping(false);
  }

  function fmtTime(s){return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0');}
  const c=exColor(ex.id);

  return React.createElement('div',{className:'scr'},
    React.createElement('div',{className:'wfc-top'},React.createElement('div',{className:'wfc-top-txt'},'JuandaFit')),
    React.createElement('div',{className:'hdr'},
      React.createElement('button',{className:'hdr-back',onClick:onBack},'Volver'),
      React.createElement('div',{className:'hdr-title'},ex.id),
      React.createElement('div',{style:{fontSize:10,fontWeight:700,color:c}},ex.zone||'')
    ),
    React.createElement('div',{className:'scrollable',style:{padding:14,background:'#0d1b2a'}},

      // Cabecera del ejercicio
      React.createElement('div',{style:{
        display:'flex',gap:14,alignItems:'center',
        background:'#152535',borderRadius:18,padding:14,
        border:'1.5px solid '+c+'44',marginBottom:12,
        borderLeft:'4px solid '+c
      }},
        React.createElement('div',{style:{width:72,height:72,borderRadius:14,overflow:'hidden',background:'#0d1b2a',flexShrink:0,display:'flex',alignItems:'center',justifyContent:'center',border:'1px solid '+c+'33'}},
          getExerciseImage(ex,exInfo)?
