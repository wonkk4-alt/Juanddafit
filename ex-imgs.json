var auth, db_fs;
var __jfFirebasePromise = null;

function jfLoadScriptOnce(src){
  const key = 'jf_cache_' + src.replace(/[^a-z0-9]+/gi,'_').slice(0,80);
  const testFirebase = function(){
    if(src.indexOf('firebase-app-compat')>-1) return typeof firebase !== 'undefined';
    if(src.indexOf('firebase-auth-compat')>-1) return typeof firebase !== 'undefined' && !!firebase.auth;
    if(src.indexOf('firebase-firestore-compat')>-1) return typeof firebase !== 'undefined' && !!firebase.firestore;
    return false;
  };
  function evalCode(code){
    const s=document.createElement('script');
    s.text=String(code||'')+'\\n//# sourceURL='+key+'.js';
    document.head.appendChild(s);
    setTimeout(()=>{try{s.remove();}catch(e){}},0);
  }
  function fetchTextFast(url, timeoutMs){
    var controller = window.AbortController ? new AbortController() : null;
    var timer = controller ? setTimeout(function(){ try{controller.abort();}catch(e){} }, timeoutMs||2500) : null;
    return fetch(url,{cache:'force-cache', mode:'cors', signal: controller ? controller.signal : undefined})
      .then(function(res){ if(!res.ok) throw new Error('HTTP '+res.status); return res.text(); })
      .finally(function(){ if(timer) clearTimeout(timer); });
  }
  async function fetchAndEval(){
    try{
      const cached=localStorage.getItem(key);
      if(cached){
        evalCode(cached);
        if(testFirebase()) return true;
      }
    }catch(e){}
    try{
      const txt=await fetchTextFast(src, 2400);
      try{localStorage.setItem(key, txt);}catch(e){}
      evalCode(txt);
      if(testFirebase()) return true;
    }catch(e){ console.warn('firebase fetch fallback:', src, e); }

    return new Promise(function(resolve, reject){
      if(document.querySelector('script[data-jf-dynamic="'+src+'"]')){
        var existing = document.querySelector('script[data-jf-dynamic="'+src+'"]');
        if(existing.getAttribute('data-loaded') === '1' && testFirebase()) return resolve(true);
        existing.addEventListener('load', function(){
          setTimeout(function(){
            if(testFirebase()) resolve(true);
            else reject(new Error('Firebase no expuso el módulo esperado: '+src));
          }, 0);
        }, {once:true});
        existing.addEventListener('error', reject, {once:true});
        return;
      }
      var s = document.createElement('script');
      s.src = src;
      s.async = true;
      s.setAttribute('data-jf-dynamic', src);
      s.onload = function(){
        s.setAttribute('data-loaded','1');
        setTimeout(function(){
          if(testFirebase()) resolve(true);
          else reject(new Error('Firebase no expuso el módulo esperado: '+src));
        }, 0);
      };
      s.onerror = function(){ reject(new Error('No se pudo cargar Firebase: '+src)); };
      document.head.appendChild(s);
    });
  }
  return fetchAndEval();
}

function jfLoadFirebaseLibs(){
  if(typeof firebase !== 'undefined' && firebase.auth && firebase.firestore) return Promise.resolve(true);
  if(__jfFirebasePromise) return __jfFirebasePromise;
  __jfFirebasePromise = jfLoadScriptOnce('https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js')
    .then(function(){ return jfLoadScriptOnce('https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js'); })
    .then(function(){ return jfLoadScriptOnce('https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js'); })
    .then(function(){ return true; });
  return __jfFirebasePromise;
}

async function ensureFirebaseReady(){
  if(auth && db_fs) return true;
  try{
    await jfLoadFirebaseLibs();
    var ok = initFirebaseOnce();
    if(!ok || !auth || !db_fs){
      __jfFirebasePromise = null;
      throw new Error('Firebase no quedó inicializado.');
    }
    return true;
  }catch(e){
    __jfFirebasePromise = null;
    console.error('Firebase ready error:', e);
    throw new Error('No se pudo conectar con Firebase. Verifica conexión a internet, que Firebase esté habilitado y recarga la página.');
  }
}

function jfStartFirebaseWatch(factory, label){
  var stopped = false;
  var unsub = null;
  ensureFirebaseReady().then(function(){
    if(stopped) return;
    try{ unsub = factory(); }
    catch(e){ console.warn((label||'watch')+' setup error:', e); }
  }).catch(function(e){
    console.warn((label||'watch')+' firebase load error:', e);
  });
  return function(){
    stopped = true;
    if(typeof unsub === 'function'){
      try{ unsub(); }catch(e){}
    }
  };
}

