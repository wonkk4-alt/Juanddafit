            React.createElement('div',{style:{display:'flex',alignItems:'center',gap:8}},
              React.createElement('div',{style:{width:8,height:8,borderRadius:'50%',background:catColor(cat)}}),
              React.createElement('span',{style:{fontWeight:700,fontSize:13,color:'#e2f7fb'}},cat)
            ),
            React.createElement('span',{style:{color:'#7aadbe',fontSize:12}},openCat===cat?'▲':exsList.length+' ▼')
          ),
          openCat===cat&&React.createElement('div',{style:{background:'#152535',borderRadius:10,border:'1px solid #1e4a6a',overflow:'hidden',marginTop:4}},
            exsList.map(ex=>{
              const inRtn=!!exercises.find(e=>e.id===ex.id);
              return React.createElement('div',{key:ex.id,onClick:()=>addEx(ex),style:{display:'flex',alignItems:'center',gap:10,padding:'10px 12px',borderBottom:'1px solid #1e3a4a',cursor:'pointer',background:inRtn?catColor(cat)+'10':'transparent'}},
                React.createElement('div',{style:{width:36,height:36,borderRadius:6,background:catColor(cat)+'22',border:'1px solid '+catColor(cat)+'33',overflow:'hidden',flexShrink:0,display:'flex',alignItems:'center',justifyContent:'center',fontSize:9,fontWeight:900,color:catColor(cat)}},
                  getExerciseImage(ex)?React.createElement('img',{loading:'lazy',decoding:'async',src:getExerciseImage(ex),style:{width:'100%',height:'100%',objectFit:'contain'}}):React.createElement('img',{loading:'lazy',decoding:'async',src:IMG_PLACEHOLDER,style:{width:'100%',height:'100%',objectFit:'contain',opacity:0.4}})
                ),
                React.createElement('span',{style:{flex:1,fontSize:12,fontWeight:inRtn?700:500,color:inRtn?catColor(cat):'#e2f7fb'}},getExerciseName(ex,null)),
                ex.custom&&React.createElement('span',{style:{fontSize:9,color:'#f59e0b',fontWeight:800,marginRight:4}},'NUEVO'),
                React.createElement('button',{
                  onClick:e=>{e.stopPropagation();deleteExerciseFromApp(ex);},
                  disabled:deletingExId===ex.id,
                  style:{padding:'4px 7px',borderRadius:6,border:'1px solid #ef444455',background:'#3d0d0d',color:'#ef4444',fontSize:10,fontWeight:800,cursor:'pointer'}
                },deletingExId===ex.id?'...':'Borrar'),
                React.createElement('span',{style:{color:inRtn?catColor(cat):'#00bcd4',fontWeight:700,fontSize:14}},inRtn?'✓':'+')
              );
            })
          )
        ))
      )
    )
  );
}

// ─── RENDER ───────────────────────────────────────────────────────────────────
(function bootJuandaFit(){
  function showMissingDeps(){
    document.body.style.cssText = 'background:#0d1b2a;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;font-family:sans-serif;';
    document.body.innerHTML = '<div style="text-align:center;color:#e2f7fb;padding:32px;max-width:320px"><div style="font-size:48px;margin-bottom:16px">📡</div><div style="font-size:18px;font-weight:700;color:#00bcd4;margin-bottom:12px">No se pudo cargar JuandaFit</div><div style="font-size:13px;color:#a8cdd8;line-height:1.6">Verifica la conexión a internet y recarga la página.</div><button onclick="location.reload()" style="margin-top:20px;padding:12px 24px;border-radius:12px;border:none;background:#00bcd4;color:#fff;font-weight:700;font-size:14px;cursor:pointer">Reintentar</button></div>';
  }

  function start(){
    if(typeof React === 'undefined' || typeof ReactDOM === 'undefined'){
      showMissingDeps();
      return;
    }
    // Primero pintar la app; luego precargar Firebase en segundo plano para que el login no se sienta lento.
    var warmFirebase = function(){
      ensureFirebaseReady().catch(function(e){
        console.warn('Firebase background init deferred:', e);
      });
    };
    if(window.requestIdleCallback){
      requestIdleCallback(warmFirebase, {timeout: 1200});
    }else{
      setTimeout(warmFirebase, 900);
    }
    ({useState,useEffect,useRef,useCallback} = React);
    const root=document.getElementById('root');
    if(!root){ showMissingDeps(); return; }
    root.innerHTML='';
    ReactDOM.createRoot(root).render(React.createElement(ErrorBoundary,null,React.createElement(App)));
  }

  if(document.readyState === 'loading'){
    window.addEventListener('DOMContentLoaded', start);
  }else{
    setTimeout(start,0);
  }
})();

