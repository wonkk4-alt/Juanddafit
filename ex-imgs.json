  const todayIdx = new Date().getDay(); // 0=dom,1=lun...
  const todayKey = DAY_KEYS[todayIdx===0?6:todayIdx-1];

  useEffect(()=>{
    async function load(){
      const[att,rtn]=await Promise.all([DB.getWeekAtt(user.uid),DB.getAllRoutines(user.uid)]);
      setWeekAtt(att);setRoutines(rtn);
    }
    load();
  },[user.email,ver]);

  function refresh(){setVer(v=>v+1);}

