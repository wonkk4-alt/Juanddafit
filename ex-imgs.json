  if(isAccessBlocked(user)) return React.createElement(AccessBlockedScreen,{user,onLogout,onProfile:()=>setScr('profile')});
  if(scr==='training'&&selDay) return React.createElement(TrainingScreen,{user,day:selDay,routines,weekAtt,onBack:()=>{setScr('home');refresh();},onSelectEx:ex=>{setSelEx(ex);setScr('exercise');}});
  if(scr==='exercise'&&selEx&&selDay) return React.createElement(ExerciseScreen,{user,day:selDay,exercise:selEx,routine:routines[selDay]||[],onBack:()=>{setScr('training');refresh();}});

