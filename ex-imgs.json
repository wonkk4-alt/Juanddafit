// ─── TRAINER LOGIN ─────────────────────────────────────────────────────────────
function TrainerLoginScreen({onBack, onLogin}){
  const [pin,setPin]=useState('');
  const [err,setErr]=useState('');
  const [loading,setLoading]=useState(false);

  useEffect(()=>{
    ensureFirebaseReady().catch(e=>console.warn('trainer login firebase preload:', e));
  },[]);

  async function doLogin(){
    if(!pin||pin.length<3){setErr('Ingresa tu PIN');return;}
    setLoading(true);setErr('');
    try{
      // 0. Asegurar que Firebase esté listo antes de usar db_fs
      await ensureFirebaseReady();
      // 1. Verificar PIN en Firestore (lectura pública)
      const snap = await db_fs.collection('users').where('role','==','trainer').limit(1).get();
      if(snap.empty) throw new Error('No hay entrenador registrado.');
      const trainerDoc = snap.docs[0].data();
      if(String(trainerDoc.pin) !== String(pin)) throw new Error('PIN incorrecto.');

      // 2. Autenticar con Firebase Auth real (email+PIN como password)
      // Esto permite escribir en Firestore con las reglas normales
      const email = trainerDoc.email;
      const password = 'juandafit_' + pin; // password derivada del PIN
      try{
        await auth.signInWithEmailAndPassword(email, password);
      }catch(authErr){
        if(authErr.code === 'auth/user-not-found' || authErr.code === 'auth/invalid-credential' || authErr.code === 'auth/wrong-password'){
          // Primera vez: crear el usuario en Firebase Auth
          try{
            await auth.createUserWithEmailAndPassword(email, password);
          }catch(createErr){
            // Si ya existe pero con otra contraseña, actualizar
            console.warn('Auth create error:', createErr.code);
          }
        }
      }

      localStorage.setItem('jf_current_session', email);
      const theme = getTrainerTheme(0);
      if(onLogin) onLogin({...trainerDoc,...theme}, null);
    }catch(e){
      setLoading(false);
      setErr(e.message||'PIN incorrecto. Intenta de nuevo.');
    }
  }

  return React.createElement('div',{className:'scr',style:{background:'#0d1b2a'}},
    React.createElement('div',{className:'wfc-top'},React.createElement('div',{className:'wfc-top-txt'},'JuandaFit')),
    React.createElement('div',{className:'scrollable',style:{padding:24,display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',minHeight:'80vh'}},
      React.createElement('img',{loading:'lazy',decoding:'async',src:LOGO_SRC,style:{width:110,display:'block',margin:'0 auto 24px',filter:'drop-shadow(0 0 20px #00bcd440)'}}),
      React.createElement('div',{style:{fontSize:20,fontWeight:900,color:'#e2f7fb',textAlign:'center',marginBottom:6,fontFamily:"'Rajdhani',sans-serif",letterSpacing:'.05em'}},'Acceso Entrenador'),
      React.createElement('div',{style:{fontSize:12,color:'#7aadbe',textAlign:'center',marginBottom:28}},'Ingresa tu PIN para continuar'),
      React.createElement('div',{style:{width:'100%',maxWidth:280}},
        React.createElement('input',{
          className:'inp',
          type:'password',
          inputMode:'numeric',
          value:pin,
          onChange:e=>setPin(e.target.value),
          onKeyDown:e=>{if(e.key==='Enter')doLogin();},
          placeholder:'PIN',
          style:{
            textAlign:'center',
            fontSize:28,
            fontWeight:900,
            letterSpacing:'0.3em',
            fontFamily:"'Rajdhani',sans-serif",
            marginBottom:16
          }
        }),
        err&&React.createElement('div',{className:'err',style:{marginBottom:12}},err),
        loading?
          React.createElement('div',{style:{textAlign:'center',padding:12}},React.createElement('div',{className:'spin'})):
          React.createElement('button',{className:'btn btn-primary',onClick:doLogin,style:{width:'100%',fontSize:15,padding:'14px'}},'Entrar'),
        React.createElement('button',{className:'btn btn-secondary',onClick:onBack,style:{marginTop:10,width:'100%'}},'Volver')
      )
    )
  );
}



