const DB = {

  // ── Auth ────────────────────────────────────────────────────────────────────
  async registerUser(email, password, name, tel){
    await ensureFirebaseReady();
    const cred = await auth.createUserWithEmailAndPassword(email.trim().toLowerCase(), password);
    const uid = cred.user.uid;
    const doc = {
      uid, email: email.trim().toLowerCase(), name, tel: tel||'', role:'user',
      accessStatus:'active', accessReason:'',
      profileStatus:'pending', objetivo:'', frecuencia:'', peso:'',
      estatura:'', imc:'', grasaVisceral:'', grasaCorporal:'', masaMuscular:'', edad:'', condicion:'',
      unlockedVideos: [],
      createdAt: Date.now()
    };
    await db_fs.collection('users').doc(uid).set(doc);
    return doc;
  },

  async loginUser(email, password){
    await ensureFirebaseReady();
    const cred = await auth.signInWithEmailAndPassword(email.trim().toLowerCase(), password);
    const snap = await db_fs.collection('users').doc(cred.user.uid).get();
    if(!snap.exists) throw new Error('Usuario no encontrado.');
    return snap.data();
  },

  async logoutUser(){
    await ensureFirebaseReady();
    localStorage.removeItem('jf_current_session');
    await auth.signOut();
  },

  async resetPassword(email){
    await ensureFirebaseReady();
    try{
      await auth.sendPasswordResetEmail(email.trim().toLowerCase());
    }catch(e){}
    return true;
  },

  getSession(email){
    return localStorage.getItem('jf_current_session') === email ? {email} : null;
  },

  async getUserByUid(uid){
    await ensureFirebaseReady();
    const snap = await db_fs.collection('users').doc(uid).get();
    return snap.exists ? snap.data() : null;
  },

  async getUserByEmail(email){
    await ensureFirebaseReady();
    const q = await db_fs.collection('users').where('email','==',email.trim().toLowerCase()).limit(1).get();
    if(q.empty) return null;
    return q.docs[0].data();
  },

  async saveUserProfile(uid, data){
    await ensureFirebaseReady();
    await db_fs.collection('users').doc(uid).update(data);
    return true;
  },

  async getAllUsers(){
