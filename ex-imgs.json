  },
  watchNote(uid, exId, cb){ return function(){}; },
  watchExInfo(exId, cb){ return function(){}; },
  watchMachineStatus(id, cb){ return function(){}; },
  onExerciseNote(uid, exId, cb){ return function(){}; },
  claimHelp(){ return true; },
