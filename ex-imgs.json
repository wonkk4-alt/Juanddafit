function TrainerPanel({trainer,onLogout}){
  const [users,setUsers]=useState([]);
  const [helpReqs,setHelpReqs]=useState([]);
  const [selUser,setSelUser]=useState(null);
  const [view,setView]=useState('list');
  const [search,setSearch]=useState('');
  const [deletingUser,setDeletingUser]=useState(null);

  // Polling de solicitudes de ayuda (cada 5s)
  useEffect(()=>{
    if(!trainer||!trainer.uid)return;
    // Listener en tiempo real de solicitudes de ayuda (Firestore onSnapshot)
    const unsub = db_fs.collection('helpRequests')
      .where('status','==','pending')
      .onSnapshot(snap=>{
        const reqs = snap.docs.map(d=>d.data())
          .filter(r=>(Date.now()-(r.createdAt||0))<30*60*1000)
          .sort((a,b)=>(a.createdAt||0)-(b.createdAt||0));
        setHelpReqs(reqs);
      }, err=>console.warn('helpReqs listener error',err));
    return()=>unsub();
  },[trainer&&trainer.uid]);

  // Polling de usuarios (cada 15s)
  useEffect(()=>{
    // Listener en tiempo real de usuarios (Firestore onSnapshot)
    const unsub = db_fs.collection('users')
      .where('role','==','user')
      .onSnapshot(snap=>{
        setUsers(snap.docs.map(d=>d.data()));
      }, err=>console.warn('users listener error',err));
    return()=>unsub();
  },[]);

  async function deleteUser(u){
    const ok=window.confirm('¿Eliminar a '+u.name+' definitivamente?\n\nEsto borrará su perfil, rutinas y notas. No se puede deshacer.');
    if(!ok)return;
    setDeletingUser(u.uid||u.email);
    try{
      await DB.deleteUserData(u.uid||u.email,u.email,trainer);
      setUsers(us=>us.filter(x=>(x.uid||x.email)!==(u.uid||u.email)));
    }catch(e){
      alert('Error al eliminar: '+(e.message||'intenta de nuevo'));
    }
    setDeletingUser(null);
  }

  async function resolveReq(userId){
    try{ await DB.resolveHelp(userId); }
    catch(e){ console.error('resolve error',e); }
  }

  if(view==='ficha'&&selUser) return React.createElement(UserFicha,{user:selUser,trainer,onBack:()=>{setView('list');setSelUser(null);}});

  const filtered=search?users.filter(u=>u.name&&u.name.toLowerCase().includes(search.toLowerCase())):users;


  return React.createElement('div',{className:'scr'},
    React.createElement('div',{className:'wfc-top'},React.createElement('div',{className:'wfc-top-txt'},'JuandaFit')),
    React.createElement('div',{className:'hdr'},
      React.createElement('div',null,
        React.createElement('div',{style:{fontWeight:800,fontSize:14,color:'#00bcd4'}},trainer.name),
        React.createElement('div',{style:{fontSize:11,color:'#a8cdd8'}},'Panel Entrenador')
      ),
      React.createElement('button',{onClick:onLogout,style:{
        border:'1px solid #00bcd440',background:'transparent',color:'#00bcd4',
        borderRadius:10,padding:'6px 12px',fontSize:12,fontWeight:700,cursor:'pointer'
      }},'Salir')
    ),
    React.createElement('div',{className:'scrollable',style:{padding:14,background:'#0d1b2a'}},

      // ── Solicitudes de ayuda ──
      helpReqs.length>0&&React.createElement('div',{style:{marginBottom:16}},
        React.createElement('div',{style:{
          fontSize:10,fontWeight:900,color:'#7c3aed',letterSpacing:'.1em',marginBottom:10
        }},'SOLICITUDES ACTIVAS ('+helpReqs.length+')'),
        helpReqs.map(req=>{
          const mins=Math.round((Date.now()-(req.createdAt||0))/60000);
          const urgColor=mins>=10?'#ef4444':mins>=5?'#f59e0b':'#7c3aed';
          return React.createElement('div',{key:req.userId,style:{
            background:'linear-gradient(135deg,#1a0a2e,#0f1a30)',
            border:'1.5px solid '+urgColor+'55',
            borderRadius:16,padding:'14px',marginBottom:8,
            display:'flex',gap:12,alignItems:'flex-start'
          }},
            React.createElement('div',{style:{
              width:44,height:44,borderRadius:12,flexShrink:0,
              background:'linear-gradient(135deg,'+urgColor+','+urgColor+'aa)',
              display:'flex',alignItems:'center',justifyContent:'center',
              fontSize:20,boxShadow:'0 4px 14px '+urgColor+'40'
            }},''),
            React.createElement('div',{style:{flex:1}},
              React.createElement('div',{style:{fontWeight:700,color:'#e2f7fb',fontSize:14}},req.userName),
              React.createElement('div',{style:{fontSize:11,color:'#b8d5de',marginTop:2}},
                (req.exercise?req.exercise+' · ':'')+req.day),
              React.createElement('div',{style:{fontSize:10,color:urgColor,fontWeight:700,marginTop:4}},
                mins<1?'Ahora mismo':'Hace '+mins+' min')
            ),
            React.createElement('div',{style:{display:'flex',flexDirection:'column',gap:6}},
              React.createElement('button',{
                onClick:()=>resolveReq(req.userId),
                style:{padding:'7px 12px',borderRadius:10,border:'none',
                  background:'#16a34a',color:'#fff',fontWeight:700,fontSize:11,cursor:'pointer'}
              },'Atendido'),
              React.createElement('button',{
                onClick:()=>{setSelUser(users.find(u=>u.uid===req.userId||u.email===req.userEmail));setView('ficha');},
                style:{padding:'7px 12px',borderRadius:10,border:'1px solid #00bcd440',
                  background:'transparent',color:'#00bcd4',fontWeight:700,fontSize:11,cursor:'pointer'}
              },'Ver ficha')
            )
          );
        })
      ),

      // ── Buscador ──
      React.createElement('input',{
        className:'inp',
        placeholder:'Buscar cliente...',
        value:search,
        onChange:e=>setSearch(e.target.value),
        style:{marginBottom:12,fontSize:14}
      }),

      // ── Lista de clientes ──
      React.createElement('div',{style:{fontSize:10,fontWeight:900,color:'#7aadbe',letterSpacing:'.1em',marginBottom:10}},
        'CLIENTES ('+filtered.length+')'),
      filtered.length===0&&React.createElement('div',{style:{textAlign:'center',color:'#7aadbe',padding:30,fontSize:13}},
        search?'No se encontró ningún cliente.':'Sin clientes registrados aún.'),
      filtered.map(u=>React.createElement(UserCard,{key:u.email||u.uid,u,onSelect:u=>{setSelUser(u);setView('ficha');},onDelete:deleteUser,deleting:deletingUser===(u.uid||u.email)}))
    )
  );
}


function UserFicha({user:u,trainer,onBack}){
  var trainerColor=(trainer&&trainer.color)||'#00bcd4';
  var trainerLight=(trainer&&trainer.light)||'#152535';
  const [routines,setRoutines]=useState({});
  const [weekAtt,setWeekAtt]=useState({});
  const [selDay,setSelDay]=useState(null);
  const [editMode,setEditMode]=useState(false);
  const [dayRtn,setDayRtn]=useState([]);
  const [notes,setNotes]=useState({});
  const [loading,setLoading]=useState(false);
  const [ver,setVer]=useState(0);
  // Profile editing (trainer only)
  const [profileTab,setProfileTab]=useState('routine'); // routine | profile | videos
  const [pDraft,setPDraft]=useState({...u});
  const [savingProfile,setSavingProfile]=useState(false);
  const [profileSaved,setProfileSaved]=useState(false);
  const [unlockedVideos,setUnlockedVideos]=useState(null); // null = not loaded
  const [savingVideos,setSavingVideos]=useState(false);
  const [videosSaved,setVideosSaved]=useState(false);

  const ALL_OBJECTIVES=['Acondicionamiento','Hipertrofia','Fuerza general','Resistencia','Tonificación','Movilidad','Rehabilitación','Pérdida de grasa','Desafío de fuerza'];

  function toggleObj(o){
    const cur=Array.isArray(pDraft.objetivo)?pDraft.objetivo:(pDraft.objetivo?[pDraft.objetivo]:[]);
    const next=cur.includes(o)?cur.filter(x=>x!==o):[...cur,o];
    setPDraft(d=>({...d,objetivo:next}));
  }

  async function handleAvatarUpload(e){
    const file=e.target.files&&e.target.files[0];
    if(!file)return;
    if(file.size>2000000){alert('Imagen demasiado grande. Máximo 2 MB.');return;}
    try{
      const result=await DB.uploadAvatar(u.email,file);
      // Si usó Storage, guardar URL; si base64, guardar data URL
      setPDraft(d=>({...d,avatar:result.url,avatarType:result.type}));
    }catch(err){
      // Fallback a base64 si hay error
      if(file.size>500000){alert('Error al subir la imagen. Intenta con una más pequeña (máx 500 KB).');return;}
      const reader=new FileReader();
      reader.onload=ev=>setPDraft(d=>({...d,avatar:ev.target.result,avatarType:'base64'}));
      reader.readAsDataURL(file);
    }
  }

  async function saveProfile(){
    setSavingProfile(true);
    const dataToSave={...pDraft,profileStatus:'active',accessStatus:getAccessStatus(pDraft),accessBlocked:isAccessBlocked(pDraft),accessUpdatedAt:Date.now()};
    // Trainer token enforced — 'trainer' role check in DB helper
    await DB.saveUserProfile(u.uid||u.email,dataToSave,trainer);
    setSavingProfile(false);
    setProfileSaved(true);
    setTimeout(()=>setProfileSaved(false),2500);
  }

  useEffect(()=>{
    let mounted = true;
    async function load(){
      if(mounted) setLoading(true);
      try{
        const rtn = await DB.getAllRoutines(u.uid||u.email);
        const att = await DB.getWeekAtt(u.uid||u.email);
        if(mounted){ setRoutines(rtn||{}); setWeekAtt(att||{}); }
      }catch(e){
        console.error('UserFicha load error:', e);
      }finally{
        if(mounted) setLoading(false);
      }
    }
    load();
    return ()=>{ mounted=false; };
  },[u.uid,u.email,ver]);

  async function loadNotes(exIds){
    const n={};
    for(const id of exIds){n[id]=await DB.getNote(u.uid||u.email,id);}
    setNotes(n);
  }

  function openDay(dk){
    setSelDay(dk);
    const exs=routines[dk]||[];
    setDayRtn(exs.map(ex=>({...ex})));
    loadNotes(exs.map(e=>e.id));
    setEditMode(false);
  }

  async function saveDay(){
    try{
      await DB.saveRoutine(u.uid||u.email,selDay,dayRtn);
      setRoutines(r=>({...r,[selDay]:dayRtn}));
      setVer(v=>v+1);
      setSelDay(null);
    }catch(e){
      console.error('saveDay error:',e);
      alert('Error al guardar: '+(e.message||'verifica tu conexión'));
    }
  }

  function updateEx(id,field,delta){
    setDayRtn(rtn=>rtn.map(ex=>{
      if(ex.id!==id)return ex;
      const cur=parseInt(ex[field])||( field==='sets'?3:10);
      return {...ex,[field]:Math.max(1,cur+delta)};
    }));
  }

  const today=new Date().getDay();
  const todayKey=DAY_KEYS[today===0?6:today-1];
  const done=DAY_KEYS.filter(dk=>weekAtt[dk]&&weekAtt[dk].s==='done').length;
  const missed=DAY_KEYS.filter(dk=>weekAtt[dk]&&weekAtt[dk].s==='missed').length;

  // Day edit view
  if(selDay) return React.createElement(DayEditTrainer,{
    user:u, trainer, day:selDay, exercises:dayRtn, notes,
    onBack:()=>setSelDay(null),
    onSave:saveDay,
    onUpdateEx:updateEx,
    onSetRtn:setDayRtn,
    onSaveNote:async(exId,note)=>{
      await DB.saveNote(u.uid||u.email,exId,note,trainer);
      setNotes(n=>({...n,[exId]:note}));
    }
  });

  return React.createElement('div',{className:'scr'},
    React.createElement('div',{className:'wfc-top'},React.createElement('div',{className:'wfc-top-txt'},'JuandaFit')),
    React.createElement('div',{className:'hdr'},
      React.createElement('button',{className:'hdr-back',onClick:onBack},'Volver'),
      React.createElement('div',{className:'hdr-title'},'FICHA: '+(u.name||u.email||'Usuario').toUpperCase())
    ),
    // Tabs: Rutina | Perfil | Videos
    React.createElement('div',{style:{display:'flex',background:'#152535',borderBottom:'1px solid #00bcd420',flexShrink:0}},
      [{id:'routine',label:'Rutina'},{id:'profile',label:'Perfil'},{id:'videos',label:'🔒 Videos'}].map(t=>
        React.createElement('button',{key:t.id,onClick:()=>{setProfileTab(t.id);if(t.id==='videos'&&unlockedVideos===null){DB.getUnlockedVideos(u.uid||u.email).then(v=>setUnlockedVideos(v||[])).catch(()=>setUnlockedVideos([]));}},style:{flex:1,padding:'10px',border:'none',background:'transparent',fontWeight:700,fontSize:11,color:profileTab===t.id?trainerColor:'#7aadbe',borderBottom:'2px solid '+(profileTab===t.id?trainerColor:'transparent'),cursor:'pointer'}},t.label)
      )
    ),
    loading?React.createElement('div',{style:{flex:1,display:'flex',alignItems:'center',justifyContent:'center'}},React.createElement('div',{className:'spin'})):
    profileTab==='profile'?
    // ── PROFILE EDIT TAB ────────────────────────────────────────────────────
    React.createElement('div',{className:'scrollable',style:{padding:14,background:'#0d1b2a'}},
      // Trainer banner
      React.createElement('div',{style:{background:'#152535',border:'1px solid '+trainerColor+'33',borderRadius:10,padding:'8px 12px',marginBottom:12,fontSize:11,color:trainerColor,fontWeight:700}},
        '✏ Editando perfil de: '+(u.name||u.email||'Usuario')+' — Solo el entrenador puede modificar estos datos.'
      ),
      // Avatar
      React.createElement('div',{style:{textAlign:'center',marginBottom:16}},
        React.createElement(AvatarCircle,{user:pDraft,size:80,fontSize:32}),
        React.createElement('div',{style:{marginTop:10}},
          React.createElement('label',{style:{display:'inline-block',padding:'7px 16px',background:trainerColor,borderRadius:8,color:'#fff',fontWeight:700,fontSize:12,cursor:'pointer'}},
            'Cambiar foto',
            React.createElement('input',{type:'file',accept:'image/*',onChange:handleAvatarUpload,style:{display:'none'}})
          )
        ),
        pDraft.avatar&&React.createElement('button',{onClick:()=>setPDraft(d=>({...d,avatar:''})),style:{marginTop:6,display:'block',margin:'6px auto 0',background:'transparent',border:'none',color:'#7aadbe',fontSize:11,cursor:'pointer'}},'✕ Quitar foto')
      ),
      // Fields
      React.createElement('div',{className:'card',style:{marginBottom:10}},
        React.createElement('div',{style:{fontSize:10,fontWeight:900,color:'#7aadbe',letterSpacing:'.08em',marginBottom:8}},'DATOS PERSONALES'),
        [['NOMBRE','name','text'],['EDAD','age','number'],['CONDICIÓN MÉDICA','cond','text']].map(([lbl,key,type])=>
