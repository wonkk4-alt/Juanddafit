// ─── TOAST helper ─────────────────────────────────────────────────────────────
function Toast({msg,type='ok'}){
  const bg = type==='err'?'#ef4444':type==='warn'?'#f59e0b':'#22c55e';
  return msg?React.createElement('div',{style:{position:'fixed',bottom:20,left:'50%',transform:'translateX(-50%)',background:bg,color:'#fff',padding:'10px 20px',borderRadius:10,fontWeight:700,fontSize:13,zIndex:999,boxShadow:'0 4px 16px rgba(0,0,0,.2)',animation:'fadeIn .2s ease'}},msg):null;
}
function useToast(){
  const [toast,setToast]=useState(null);
  function show(msg,type='ok',ms=2500){
    setToast({msg,type});
    setTimeout(()=>setToast(null),ms);
  }
  return [toast,show];
}

// ─── LOGIN / REGISTER ─────────────────────────────────────────────────────────
function LoginScreen({onBack, onLogin}){
  const [mode,setMode]=useState('login'); // login | register | reset
  const [nm,setNm]=useState('');
  const [em,setEm]=useState('');
  const [pw,setPw]=useState('');
  const [tel,setTel]=useState('');
  const [err,setErr]=useState('');
  const [info,setInfo]=useState(''); // mensaje neutro de confirmación
  const [loading,setLoading]=useState(false);

  useEffect(()=>{
    ensureFirebaseReady().catch(e=>console.warn('user login firebase preload:', e));
  },[]);
  const [toast,showToast]=useToast();

  async function doLogin(){
    if(!em||!pw){setErr('Completa todos los campos');return;}
    setLoading(true);setErr('');
    try{
      const doc = await DB.loginUser(em.trim().toLowerCase(), pw);
      localStorage.setItem('jf_current_session', em.trim().toLowerCase());
      if(doc.role==='trainer'){
        const theme = getTrainerTheme(doc.colorIdx||0);
        onLogin({...doc,...theme}, null);
      } else {
        onLogin(null, doc);
      }
    }catch(e){
      setLoading(false);
      setErr(e.message||'Email o contraseña incorrectos');
    }
  }

  async function doReset(){
    if(!em){setErr('Ingresa tu correo electrónico');return;}
    setLoading(true);setErr('');setInfo('');
    const result = await DB.resetPassword(em.trim().toLowerCase());
    setLoading(false);
    // Mostrar siempre mensaje neutro — no revela si el email existe
    setInfo(result.message);
  }

  async function doRegister(){
    if(!nm||!em||!pw){setErr('Completa todos los campos');return;}
    if(pw.length<6){setErr('Contraseña mínimo 6 caracteres');return;}
    setLoading(true);setErr('');
    try{
