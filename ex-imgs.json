const ALL_EXERCISES = Object.values(CAT).filter(Array.isArray).flat();
function getEx(id){return Object.values(CAT).filter(Array.isArray).flat().find(e=>e.id===id);}
function catColor(cat){
  const colors={'PECHO · HOMBRO · TRICEPS':'#ef4444','ESPALDA · BICEPS':'#3b82f6','PIERNA':'#22c55e','GLÚTEO':'#a855f7','PILAR · ESTABILIDAD':'#f59e0b','MOVILIDAD':'#06b6d4','CARDIO · VASCULAR':'#00bcd4','ESTIRAMIENTO':'#14b8a6'};
  return colors[cat]||'#64748b';
}
function exColor(exId){
  for(const [cat,exs] of Object.entries(CAT)){ if(Array.isArray(exs) && exs.find(e=>e.id===exId)) return catColor(cat); }
  return '#64748b';
}
function getCategoryOptions(){
  return Object.keys(CAT).filter(k=>Array.isArray(CAT[k]));
}
const DELETED_EXERCISES = {};
function isExerciseDeleted(id){ return !!(id && DELETED_EXERCISES[id]); }
function removeExerciseFromCatalogLocal(id){
  if(!id)return;
  Object.keys(CAT).forEach(cat=>{
    if(Array.isArray(CAT[cat])) CAT[cat] = CAT[cat].filter(ex=>ex && ex.id!==id);
  });
}
function applyDeletedExerciseIds(ids){
  if(!Array.isArray(ids))return;
  ids.filter(Boolean).forEach(id=>{
    DELETED_EXERCISES[id]=true;
    removeExerciseFromCatalogLocal(id);
  });
}
function mergeCustomExercises(customs){
  if(!Array.isArray(customs))return;
  customs.forEach(raw=>{
    if(!raw || !raw.id || !raw.name || raw.deleted || isExerciseDeleted(raw.id))return;
    const cat = raw.category || raw.cat || getCategoryOptions()[0];
    if(!cat || !CAT[cat])return;
    const ex = {
      id: raw.id,
      name: raw.name,
      zone: raw.zone || 'Personalizado',
      machine: raw.machine || 'Personalizado',
      video: raw.video || (raw.links&&raw.links[0]&&raw.links[0].url) || '',
      category: cat,
      custom: true,
      customImg: raw.customImg || raw.image || ''
    };
    const idx = CAT[cat].findIndex(e=>e.id===ex.id);
    if(idx>=0)CAT[cat][idx]={...CAT[cat][idx],...ex};
    else CAT[cat].push(ex);
  });
}
function defaultNewExerciseDraft(){
  return {name:'',category:getCategoryOptions()[0]||'',image:'',link:'',description:''};
}

