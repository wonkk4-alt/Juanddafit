  async saveExInfo(exId, data){
    await ensureFirebaseReady();
    await db_fs.collection('exInfo').doc(exId).set(data, {merge: true});
    // Si el ejercicio existe en el catálogo global creado por el entrenador, actualizarlo también.
    try{
      await db_fs.collection('exerciseCatalog').doc(exId).update({...data, updatedAt: Date.now()});
    }catch(e){}
    return true;
  },

  async saveExerciseInfo(exId, data){
    await ensureFirebaseReady(); return this.saveExInfo(exId, data); },

  getDeletedExerciseIdsLocal(){
    try{
      const local = JSON.parse(localStorage.getItem('jf_deleted_exercises')||'[]');
      return Array.isArray(local) ? Array.from(new Set(local.filter(Boolean))) : [];
    }catch(e){ return []; }
  },

  cacheDeletedExerciseIds(ids){
    try{
      const clean = Array.from(new Set((ids||[]).filter(Boolean)));
      localStorage.setItem('jf_deleted_exercises', JSON.stringify(clean));
      if(typeof applyDeletedExerciseIds === 'function') applyDeletedExerciseIds(clean);
      return clean;
    }catch(e){ return ids||[]; }
  },

  async getDeletedExerciseIds(){
    await ensureFirebaseReady();
    // Lectura ligera: un solo documento, no escaneo de colecciones.
    const local = this.getDeletedExerciseIdsLocal();
    try{
      const snap = await db_fs.collection('appMeta').doc('deletedExercises').get();
      const data = snap.exists ? (snap.data() || {}) : {};
      const idsField = data.ids || {};
      const remote = Array.isArray(idsField)
        ? idsField
        : Object.keys(idsField).filter(k=>idsField[k]);
      return this.cacheDeletedExerciseIds(local.concat(remote));
    }catch(e){
      console.warn('getDeletedExerciseIds compact cache fallback:', e);
      return local;
    }
  },

  refreshDeletedExerciseIds(){
    try{ this.getDeletedExerciseIds().catch(e=>console.warn('refreshDeletedExerciseIds:', e)); }catch(e){}
  },

  watchDeletedExercises(cb){
    // Listener liviano y diferido: no toca Firestore durante el primer render.
    const emit = (ids)=>{
      const clean = this.cacheDeletedExerciseIds(ids||[]);
      if(typeof cb === 'function') cb(clean);
    };
    try{ emit(this.getDeletedExerciseIdsLocal()); }catch(e){}
    return jfStartFirebaseWatch(()=>{
      return db_fs.collection('appMeta').doc('deletedExercises').onSnapshot(snap=>{
        const data = snap.exists ? (snap.data() || {}) : {};
        const idsField = data.ids || {};
        const ids = Array.isArray(idsField)
          ? idsField
          : Object.keys(idsField).filter(k=>idsField[k]);
        emit(ids);
      }, err=>console.warn('watchDeletedExercises compact error:', err));
    }, 'watchDeletedExercises');
  },

  async deleteExerciseFromApp(exercise){
    await ensureFirebaseReady();
    const id = typeof exercise === 'string' ? exercise : (exercise && exercise.id);
    if(!id) throw new Error('Ejercicio inválido.');
    const ex = typeof exercise === 'string' ? {id} : (exercise||{});
    const deletedBy = (auth && auth.currentUser && auth.currentUser.uid) || ex.deletedBy || '';
    const tombstone = {
      id,
      name: ex.name || '',
      category: ex.category || '',
      deleted: true,
      deletedAt: Date.now(),
      deletedBy
    };

    // Documento compacto global para que todos oculten el ejercicio.
    try{
      await db_fs.collection('appMeta').doc('deletedExercises').set({
        ids: {[id]: true},
        updatedAt: Date.now()
      }, {merge:true});
    }catch(e){
      console.warn('deleteExerciseFromApp appMeta:', e);
    }

    // Tombstone compatible con versiones anteriores.
    try{
      await db_fs.collection('exInfo').doc(id).set(tombstone, {merge:true});
    }catch(e){
      console.warn('deleteExerciseFromApp exInfo:', e);
    }

    // Si era ejercicio creado por entrenador, se retira del catálogo global.
    try{ await db_fs.collection('exerciseCatalog').doc(id).delete(); }
    catch(e){ console.warn('deleteExerciseFromApp exerciseCatalog delete:', e); }

    try{
      const local = JSON.parse(localStorage.getItem('jf_custom_exercises')||'[]').filter(x=>x&&x.id!==id);
      localStorage.setItem('jf_custom_exercises', JSON.stringify(local));
      const deleted = this.getDeletedExerciseIdsLocal();
      if(!deleted.includes(id)) deleted.push(id);
      this.cacheDeletedExerciseIds(deleted);
    }catch(e){}
    return true;
  },

  async getCustomExercises(){
    await ensureFirebaseReady();
    let items=[];

    // Fuente principal: catálogo global. Lo que se cree aquí aparece para todos
    // los entrenadores/clientes que carguen el catálogo.
    try{
      const q = await db_fs.collection('exerciseCatalog').where('global','==',true).get();
      items = items.concat(q.docs.map(d=>({id:d.id,...d.data()})));
    }catch(e){
      console.warn('getCustomExercises exerciseCatalog error:', e);
    }

    // Compatibilidad con versiones anteriores que guardaban los ejercicios en exInfo.
    try{
      const q2 = await db_fs.collection('exInfo').where('isCustomExercise','==',true).get();
      items = items.concat(q2.docs.map(d=>({id:d.id,...d.data()})));
    }catch(e){
      console.warn('getCustomExercises exInfo legacy error:', e);
    }

    // Fallback local solo para que el creador vea lo recién creado si hay latencia.
    try{
      const local = JSON.parse(localStorage.getItem('jf_custom_exercises')||'[]');
      if(Array.isArray(local))items = items.concat(local);
    }catch(e){}

    const seen={};
    return items.filter(x=>x&&x.id&&!x.deleted&&!seen[x.id]&&(seen[x.id]=true));
  },

  async saveCustomExercise(exercise, info){
    await ensureFirebaseReady();
    const now=Date.now();
    const payload = {
      ...exercise,
      ...info,
      id: exercise.id,
      name: exercise.name || info.name || '',
      category: exercise.category || info.category || '',
      zone: exercise.zone || info.zone || 'Personalizado',
      machine: exercise.machine || info.machine || 'Personalizado',
      video: exercise.video || info.video || '',
      customImg: exercise.customImg || info.customImg || info.image || '',
      global: true,
      isGlobalExercise: true,
      isCustomExercise: true,
      custom: true,
      createdAt: info.createdAt || now,
      updatedAt: now
    };

    // Guardado global del catálogo: todos leen de aquí.
    // Si las reglas de Firestore aún no permiten esta colección nueva, no se rompe:
    // exInfo queda como respaldo global compatible con la versión anterior.
    try{
      await db_fs.collection('exerciseCatalog').doc(payload.id).set(payload, {merge:true});
    }catch(e){
      console.warn('saveCustomExercise exerciseCatalog fallback to exInfo:', e);
    }

    // Guardado paralelo de info del ejercicio: descripción, imagen y links usados
    // por ExerciseScreen, por la edición global existente y como respaldo global.
    await db_fs.collection('exInfo').doc(payload.id).set(payload, {merge:true});

    try{
      const local = JSON.parse(localStorage.getItem('jf_custom_exercises')||'[]').filter(x=>x&&x.id!==payload.id);
      local.push(payload);
      localStorage.setItem('jf_custom_exercises', JSON.stringify(local));
    }catch(e){}
    return payload;
  },

  watchCustomExercises(cb){
    return jfStartFirebaseWatch(function(){
      return db_fs.collection('exerciseCatalog')
        .where('global','==',true)
        .onSnapshot(snap=>{
          cb(snap.docs.map(d=>({id:d.id,...d.data()})).filter(x=>!x.deleted));
        }, err=>console.warn('watchCustomExercises error:', err));
    }, 'watchCustomExercises');
  },

