// ─── TRAINING SCREEN ──────────────────────────────────────────────────────────
function TrainingScreen({user,day,routines,weekAtt,onBack,onSelectEx}){
  const exs = routines[day]||[];
  const att = weekAtt[day];
  const [helpSent,setHelpSent]=useState(false);
  const [helping,setHelping]=useState(false);
  const [logs,setLogs]=useState({});
  const today=new Date().toISOString().slice(0,10);

  useEffect(()=>{
    async function loadLogs(){
      const logMap={};
      for(const ex of exs){
        const l=await DB.getExerciseLog(user.uid,ex.id,today);
        if(l)logMap[ex.id]=l;
      }
      setLogs(logMap);
    }
    if(exs.length)loadLogs();
  },[day,exs.length]);

  const doneCount=Object.values(logs).filter(l=>l&&l.allDone).length;
  const pct=exs.length>0?Math.round(doneCount/exs.length*100):0;

  async function markAtt(status){
    await DB.setAtt(user.uid,day,status);
    onBack();
  }

  async function sendHelp(){
    setHelping(true);
    try{
      await DB.postHelp({userId:user.uid,userName:user.name,day:DAY_LABELS[day],
        exercisesDone:doneCount,exercisesTotal:exs.length,
        age:user.age,cond:user.cond});
      setHelpSent(true);
    }catch(e){}
    setHelping(false);
  }

  return React.createElement('div',{className:'scr'},
    React.createElement('div',{className:'wfc-top'},React.createElement('div',{className:'wfc-top-txt'},'JuandaFit')),
    React.createElement('div',{className:'hdr'},
      React.createElement('button',{className:'hdr-back',onClick:onBack},'Volver'),
      React.createElement('div',{className:'hdr-title'},'ENTRENANDO · '+DAY_LABELS[day].toUpperCase()),
      React.createElement('div',{style:{fontSize:12,fontWeight:700,color:'#00bcd4'}},pct+'%')
    ),
    React.createElement('div',{className:'scrollable',style:{padding:14,background:'#0d1b2a'}},

      // ── Barra de progreso ──
      React.createElement('div',{style:{marginBottom:16}},
        React.createElement('div',{style:{display:'flex',justifyContent:'space-between',marginBottom:6}},
          React.createElement('span',{style:{fontSize:12,color:'#a8cdd8',fontWeight:600}},'Progreso de hoy'),
          React.createElement('span',{style:{fontWeight:700,color:'#00bcd4'}},doneCount+'/'+exs.length+' ejercicios')
        ),
        React.createElement('div',{style:{background:'#152535',borderRadius:99,height:10,overflow:'hidden',border:'1px solid #1e4a6a'}},
          React.createElement('div',{style:{width:pct+'%',height:'100%',background:'linear-gradient(90deg,#00bcd4,#00e5ff)',borderRadius:99,transition:'.4s',boxShadow:pct>0?'0 0 10px #00bcd460':'none'}})
        )
      ),

      // ── Grid de ejercicios (cajitas) ──
      exs.length===0&&React.createElement('div',{style:{textAlign:'center',color:'#7aadbe',padding:30}},'Sin rutina asignada para este día.'),

      exs.length>0&&React.createElement('div',{style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10,marginBottom:16}},
        exs.map((ex,i)=>{
          const log=logs[ex.id];
          const done=log&&log.allDone;
          const c=exColor(ex.id);
          return React.createElement('div',{
            key:ex.id,
            onClick:()=>onSelectEx(ex),
            style:{
              cursor:'pointer',
              background:done?'#0d2416':'#152535',
              border:'1.5px solid '+(done?'#16a34a':c+'55'),
              borderRadius:16,
              padding:'12px 10px',
              display:'flex',flexDirection:'column',alignItems:'center',
              gap:8,
              position:'relative',
              boxShadow:done?'0 0 12px #16a34a20':'0 2px 8px #00000040',
              transition:'all .2s'
            }
