let useState, useEffect, useRef, useCallback;

function App(){
  // authReady: false mientras Firebase verifica sesión inicial
  const [authReady, setAuthReady] = useState(false);
  const [user, setUser] = useState(null);
  const [trainer, setTrainer] = useState(null);
  const [exImgsTick, setExImgsTick] = useState(0);

  useEffect(()=>{
    const refresh = ()=>setExImgsTick(x=>x+1);
    window.addEventListener('jf-ex-imgs-ready', refresh);
    return ()=>window.removeEventListener('jf-ex-imgs-ready', refresh);
  },[]);

  // Catálogo global diferido: no bloquea la pantalla inicial.
  useEffect(()=>{
    let mounted=true;
    let unsub=null;
    const timer=setTimeout(async ()=>{
      try{
        await ensureFirebaseReady();
        const customs = await DB.getCustomExercises();
        if(mounted) mergeCustomExercises(customs);
        unsub = DB.watchCustomExercises(customs=>{
          if(mounted) mergeCustomExercises(customs||[]);
        });
      }catch(e){
        console.warn('global exercise catalog deferred load error:', e);
      }
    }, 7000);
    return ()=>{mounted=false; clearTimeout(timer); if(typeof unsub==='function')unsub();};
  },[]);

  useEffect(()=>{
    // Arranque ultrarrápido: mostrar la app inmediatamente y restaurar sesión después.
    let cancelled=false;
    let unsubAuth=null;
    setAuthReady(true);

    const restoreTimer = setTimeout(async ()=>{
      try{
        await ensureFirebaseReady();
        if(cancelled || !auth) return;
        unsubAuth = auth.onAuthStateChanged(async (firebaseUser) => {
          try{
            if(firebaseUser){
              const doc = await DB.getUserByUid(firebaseUser.uid);
              if(doc && doc.role==='trainer'){
                const theme = getTrainerTheme(0);
                setTrainer({...doc,...theme});
                setUser(null);
              } else if(doc && doc.role==='user'){
                setUser(doc);
                setTrainer(null);
              }
            } else {
              const savedEmail = localStorage.getItem('jf_current_session');
              if(savedEmail){
                try{
                  const doc = await DB.getUserByEmail(savedEmail);
                  if(doc && doc.role==='trainer'){
                    const theme = getTrainerTheme(0);
                    setTrainer({...doc,...theme});
                    setUser(null);
                  }
                }catch(e){ console.warn('trainer session restore:',e); }
              }
            }
          }catch(e){ console.warn('session restore error',e); }
          setAuthReady(true);
        });
      }catch(e){
        console.warn('Firebase se cargará al iniciar sesión:', e);
        setAuthReady(true);
      }
    }, 1800);

    return ()=>{ cancelled=true; clearTimeout(restoreTimer); if(typeof unsubAuth==='function')unsubAuth(); };
  },[]);

  // Derivar pantalla del estado, no de una variable separada
  const scr = !authReady ? 'splash'
    : trainer ? 'trainer'
    : user    ? 'home'
    : 'choose';
  const setScr = (s)=>{ if(s==='choose'||s==='login'||s==='trainer_login') _setNavScr(s); };
  const [navScr, _setNavScr] = useState(function(){
    var s = (typeof window !== 'undefined') ? window.__JF_FAST_NAV : null;
    return (s==='login'||s==='trainer_login') ? s : null;
  });
  const efectiveScr = (navScr && !trainer && !user) ? navScr : scr;

  // Real-time profile listener — actualiza sin cerrar sesión
  useEffect(()=>{
    if(!user || !user.uid) return;
    const unsub = DB.watchUserProfile(user.uid, data=>{
      setUser(prev=>prev?{...prev,...data}:data);
    });
    return ()=>{ if(typeof unsub==='function') unsub(); };
  },[user&&user.uid]);

  // Activity ping
  useEffect(()=>{
    if(!user || !user.uid) return;
    DB.updateActivity(user.uid, user.name);
    const iv = setInterval(()=>DB.updateActivity(user.uid, user.name), 30000);
    return ()=>clearInterval(iv);
  },[user&&user.uid]);

  async function logout(){
    const email = localStorage.getItem('jf_current_session');
    if(email) await DB.logoutUser(email);
    localStorage.removeItem('jf_current_session');
    setUser(null); setTrainer(null); _setNavScr(null);
  }

  if(efectiveScr==='splash') return React.createElement(Splash);
  if(efectiveScr==='trainer') return React.createElement(TrainerPanel,{trainer,onLogout:logout});
  if(efectiveScr==='home')    return React.createElement(HomeScreen,{user,onLogout:logout,updateUser:setUser});
  if(efectiveScr==='login')   return React.createElement(LoginScreen,{onBack:()=>_setNavScr(null),onLogin:(tr,u)=>{if(tr){setTrainer(tr);setUser(null);}else{setUser(u);setTrainer(null);}}});
  if(efectiveScr==='trainer_login') return React.createElement(TrainerLoginScreen,{onBack:()=>_setNavScr(null),onLogin:(tr,u)=>{if(tr){setTrainer(tr);setUser(null);}else{setUser(u);setTrainer(null);}}});
  // choose
  return React.createElement(ChooseScreen,{onUser:()=>_setNavScr('login'),onTrainer:()=>_setNavScr('trainer_login')});
}

